{
  "sources": [
    {
      "id": "local-todo",
      "type": "text_file",
      "enabled": true,
      "path": "../inbox/todo.md"
    },
    {
      "id": "google-docs",
      "type": "google_docs",
      "enabled": false,
      "document_id": "YOUR_DOCUMENT_ID",
      "auth": "gcloud",
      "writeback": "mark_done"
    },
    {
      "id": "notion-page",
      "type": "notion_page",
      "enabled": false,
      "url": "https://www.notion.so/YOUR_PAGE_ID",
      "token_env": "NOTION_TOKEN",
      "writeback": "mark_done",
      "recursive": false
    }
  ]
}
